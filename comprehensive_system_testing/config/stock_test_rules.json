{
  "stock_specific_rules": {
    "fyers_integration": {
      "required_credentials": ["app_id", "access_token"],
      "test_symbols": ["NSE:SBIN-EQ", "NSE:RELIANCE-EQ", "NSE:TCS-EQ"],
      "market_hours_validation": true,
      "rate_limit_tests": true
    },
    "stock_assets": {
      "required_fields": ["symbol", "name", "exchange", "sector", "active"],
      "min_assets": 10,
      "validate_nse_symbols": true,
      "check_duplicates": true
    },
    "stock_strategies": {
      "required_methods": ["calculate_signals", "get_parameters"],
      "market_hours_aware": true,
      "sector_analysis": true,
      "fundamental_data": false
    },
    "data_validation": {
      "ohlcv_required": true,
      "corporate_actions": true,
      "dividend_adjustments": true,
      "split_adjustments": true
    }
  },
  "severity_overrides": {
    "fyers_api_failure": "CRITICAL",
    "invalid_nse_symbol": "HIGH",
    "market_hours_violation": "MEDIUM",
    "missing_stock_config": "HIGH"
  },
  "auto_fix_rules": {
    "standardize_nse_symbols": true,
    "fix_sector_names": true,
    "update_deprecated_fyers_calls": false
  }
}