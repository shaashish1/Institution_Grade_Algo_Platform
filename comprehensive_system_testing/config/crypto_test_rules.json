{
  "crypto_specific_rules": {
    "ccxt_integration": {
      "required_exchanges": ["binance", "coinbase", "kraken"],
      "test_symbols": ["BTC/USDT", "ETH/USDT", "ADA/USDT"],
      "rate_limit_tests": true,
      "sandbox_mode": true
    },
    "crypto_assets": {
      "required_fields": ["symbol", "name", "exchange", "active"],
      "min_assets": 5,
      "validate_symbols": true,
      "check_duplicates": true
    },
    "crypto_strategies": {
      "required_methods": ["calculate_signals", "get_parameters"],
      "backtest_required": true,
      "risk_management": true
    },
    "data_validation": {
      "ohlcv_required": true,
      "timestamp_validation": true,
      "price_sanity_checks": true,
      "volume_validation": true
    }
  },
  "severity_overrides": {
    "ccxt_import_failure": "CRITICAL",
    "exchange_connection_failure": "HIGH",
    "invalid_crypto_symbol": "MEDIUM",
    "missing_crypto_config": "HIGH"
  },
  "auto_fix_rules": {
    "standardize_crypto_symbols": true,
    "fix_exchange_names": true,
    "update_deprecated_ccxt_calls": false
  }
}